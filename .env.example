# Neon Postgres connection string (used by Drizzle and Better Auth)
DATABASE_URL=postgresql://user:password@your-neon-endpoint-pooler.neon.tech/neondb?sslmode=require


# PowerSync Cloud
POWERSYNC_URL=https://your-instance.powersync.journeyapps.com
# HMAC-SHA256 shared secret for signing PowerSync JWTs (min 32 chars).
# Generate with: openssl rand -base64 32
# The same key must be base64url-encoded and entered in the PowerSync dashboard.
POWERSYNC_PRIVATE_KEY=replace-with-a-256-bit-secret-min-32-chars

# Secret used to sign auth tokens (generate with: npm run auth:secret)
BETTER_AUTH_SECRET=replace-with-output-from-npm-run-auth-secret

# (Optional) Production base URL for CSRF and redirect validation
# BETTER_AUTH_URL=https://your-app.example.com

GOOGLE_GENERATIVE_AI_API_KEY=